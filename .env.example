# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tutorconnect?schema=public"

# Auth (JWT)
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins (frontend URL)
CORS_ORIGINS=http://localhost:3000
