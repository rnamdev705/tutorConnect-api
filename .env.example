# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database — Neon (recommended)
# App runtime: use the POOLED connection string from Neon dashboard (hostname contains "-pooler")
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"
# Migrations / Prisma CLI: use the DIRECT connection string (no "-pooler")
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# Database — local PostgreSQL (omit DIRECT_URL or set it equal to DATABASE_URL)
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tutorconnect?schema=public"
# DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/tutorconnect?schema=public"

# Auth (JWT)
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins (frontend URL)
CORS_ORIGINS=http://localhost:3000

# File uploads — stored in PostgreSQL (max 10 MB; allowed: pdf, docx, png, jpg)
MAX_FILE_SIZE_MB=10

# Neon WebSocket driver — only for serverless/edge deploys (Vercel, Workers). Leave false for Node/Express.
USE_NEON_DRIVER=false

# Neon free tier — ping DB every 4 min while API is running (auto-enabled for neon.tech URLs)
# DB_KEEPALIVE_ENABLED=true
# DB_KEEPALIVE_INTERVAL_MS=240000
